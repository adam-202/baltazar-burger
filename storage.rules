rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read access to all menu images
      allow read: if true;
      
      // Restrict write access to authorized admins
      allow write: if request.auth != null && (
        request.auth.token.email == "adam.osama60@gmail.com" ||
        (firestore.exists(/databases/(default)/documents/categories/admin_settings) &&
         request.auth.token.email in firestore.get(/databases/(default)/documents/categories/admin_settings).data.emails)
      );
    }
  }
}
